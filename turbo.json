{
  "$schema": "./node_modules/turbo/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test": {
      "dependsOn": ["^test"],
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "setup": {
      "dependsOn": ["^setup"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "deploy-db": {
      "dependsOn": ["^deploy-db"],
      "cache": false
    }
  }
}
