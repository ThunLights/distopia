{
  "$schema": "./node_modules/turbo/schema.json",
  "cacheDir": ".cache/turbo",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test": {
      "dependsOn": ["build", "^test"],
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "setup": {
      "dependsOn": ["^setup"],
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "deploy-db": {
      "dependsOn": ["^deploy-db"],
      "cache": false
    },
    "storybook": {
      "dependsOn": ["^storybook"],
      "cache": false
    },
    "build-storybook": {
      "dependsOn": ["^build-storybook"],
      "cache": false
    },
    "version:jsr": {
      "dependsOn": ["^version:jsr"],
      "outputs": ["jsr.json"]
    }
  }
}
