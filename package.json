{
  "name": "distopia-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "setup": "bun run prepare && turbo run setup",
    "typecheck": "turbo run typecheck",
    "deploy-db": "turbo run deploy-db",
    "version": "npx changeset version && turbo run version:jsr",
    "prepare": "husky",
    "storybook": "turbo run storybook",
    "build-storybook": "turbo run build-storybook"
  },
  "packageManager": "bun@1.3.14",
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "bun": "catalog:",
    "husky": "9.1.7",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "turbo": "2.10.5"
  },
  "peerDependencies": {
    "typescript": "catalog:"
  },
  "workspaces": {
    "packages": [
      "./lib/*",
      "./src/**/*"
    ],
    "catalog": {
      "@standard-schema/spec": "1.1.0",
      "@types/node": "24.13.3",
      "bun": "1.3.14",
      "discord.js": "14.27.0",
      "oxfmt": "0.59.0",
      "oxlint": "1.74.0",
      "typescript": "6.0.3",
      "vitest": "4.1.10",
      "zod": "4.4.3"
    }
  }
}
