{
  "name": "presentation-web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --host",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "typecheck": "npm run check",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "setup": "playwright install --with-deps && npm run build-storybook",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run && npm run test:e2e",
    "test:e2e": "playwright test",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.2.1",
    "@eslint/compat": "2.1.0",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.60.0",
    "@storybook/addon-a11y": "10.4.4",
    "@storybook/addon-docs": "10.4.4",
    "@storybook/addon-svelte-csf": "5.1.2",
    "@storybook/addon-vitest": "10.4.4",
    "@storybook/sveltekit": "10.4.4",
    "@sveltejs/adapter-node": "5.5.4",
    "@sveltejs/enhanced-img": "0.10.4",
    "@sveltejs/kit": "2.67.0",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "catalog:",
    "@vitest/browser-playwright": "4.1.9",
    "@zerodevx/svelte-toast": "0.9.6",
    "bun": "catalog:",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-storybook": "10.4.4",
    "eslint-plugin-svelte": "3.19.0",
    "globals": "17.6.0",
    "playwright": "1.60.0",
    "prettier": "3.8.4",
    "prettier-plugin-svelte": "4.1.0",
    "storybook": "10.4.6",
    "svelte": "5.56.3",
    "svelte-check": "4.6.0",
    "typescript": "catalog:",
    "typescript-eslint": "8.61.0",
    "vite": "8.0.16",
    "vite-plugin-devtools-json": "1.0.0",
    "vitest": "catalog:",
    "vitest-browser-svelte": "2.1.1"
  },
  "dependencies": {
    "@fontsource/inter": "5.2.8",
    "@fontsource/open-sans": "5.2.7",
    "@standard-schema/spec": "catalog:",
    "app-core": "workspace:*",
    "app-schedule": "workspace:*",
    "discord.js": "catalog:",
    "dotenv": "17.4.2",
    "infra-database": "workspace:*",
    "infra-discord": "workspace:*",
    "jsonwebtoken": "9.0.3",
    "presentation-bot": "workspace:*",
    "repo-memory": "workspace:*",
    "repo-search": "workspace:*",
    "super-sitemap": "1.0.12",
    "svelte-exmarkdown": "5.0.2",
    "uuid": "14.0.0",
    "zod": "catalog:"
  }
}
