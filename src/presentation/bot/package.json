{
  "name": "presentation-bot",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run scripts/cmdGen.ts",
    "setup": "npm run build",
    "test": "vitest run",
    "lint": "oxfmt --check --config ../../../lib/template/oxfmt.config.ts && oxlint --config ../../../lib/template/oxlint.config.ts",
    "lint:fix": "oxlint --fix --config ../../../lib/template/oxlint.config.ts",
    "format": "oxfmt --config ../../../lib/template/oxfmt.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "distopia-template": "workspace:*",
    "domain-service-core": "workspace:*",
    "infra-discord": "workspace:*"
  },
  "devDependencies": {
    "bun": "1.3.12",
    "oxfmt": "0.45.0",
    "oxlint": "1.60.0",
    "vitest": "4.1.4"
  },
  "peerDependencies": {
    "typescript": "6.0.2"
  }
}
