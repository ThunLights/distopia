generator client {
  provider        = "prisma-client"
  output          = "../src/prisma-client"
  previewFeatures = ["typedSql"]
  moduleFormat    = "esm"
}

generator zod {
  provider = "zod-prisma-types"
  output   = "../src/zod"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String @id
  bumpCounter Int?
}

model UserWeb {
  id           String @id
  jwtVerifykey String @default(uuid(4))
}

model UserDiscord {
  id           String   @id
  accessToken  String
  refreshToken String
  email        String?
  updatedAt    DateTime @updatedAt
}

model Friend {
  userId      String   @id
  username    String
  description String
  nsfw        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tags        String[] @default([])
}

model Guild {
  guildId      String   @id
  name         String
  invite       String
  icon         String?
  banner       String?
  description  String?
  registeredAt DateTime @default(now())
  updatedAt    DateTime @updatedAt
  nsfw         Boolean  @default(false)
  public       Boolean  @default(true)
  bumpTime     DateTime @default(now())
  tags         String[] @default([])
}

model GuildReview {
  userId  String
  guildId String
  star    Int
  content String?

  @@id([userId, guildId])
}

model GuildRecordOneDay {
  guildId          String
  date             DateTime
  vcMembers        String[] @default([])
  newMembers       String[] @default([])
  newMessages      Int      @default(0)
  vcMemberUpperTwo Int      @default(0)

  @@id([guildId, date])
}

model GuildRecord {
  guildId      String  @id
  maxlevelRank BigInt?
  maxRateRank  BigInt?
  maxRate      BigInt?
  bumpCounter  Int     @default(0)
  activeRate   BigInt?
  level        BigInt  @default(0)
  point        BigInt  @default(0)
}

model GuildSetting {
  guildId           String  @id
  actingOwner       String?
  bumpNotice        Boolean @default(false)
  bumpNoticeRole    String?
  bumpNoticeContent String?
}

model Panel {
  guildId   String
  type      PanelType
  channelId String
  messageId String

  @@id([guildId, type])
}

enum PanelType {
  ActiveRateRanking
  LevelRanking
  UserBumpRanking
}

model JWTKey {
  id        Int      @id @default(autoincrement())
  key       Bytes    @unique
  alg       JWTAlg
  createdAt DateTime @default(now())
}

enum JWTAlg {
  HS256
}
