{
  "name": "infra-database",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts"
    },
    "./types": {
      "import": "./src/types/index.ts"
    }
  },
  "scripts": {
    "build": "prisma generate && prisma generate --sql",
    "lint": "bun run lint:prisma && oxfmt --check --config ../../../lib/template/oxfmt.config.ts && oxlint --config ../../../lib/template/oxlint.config.ts",
    "lint:prisma": "prisma format --check && prisma validate",
    "lint:fix": "oxlint --fix --config ../../../lib/template/oxlint.config.ts",
    "format": "prisma format && oxfmt --config ../../../lib/template/oxfmt.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.7.0",
    "@prisma/client": "7.7.0",
    "@prisma/client-runtime-utils": "7.7.0",
    "prisma": "7.7.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "bun": "catalog:",
    "dotenv": "17.4.2",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "zod-prisma-types": "3.3.11"
  },
  "peerDependencies": {
    "typescript": "catalog:"
  }
}
