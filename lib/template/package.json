  "dependencies": {
    "oxfmt": "catalog:",
    "oxlint": "1.60.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "bun": "catalog:"
  },
  "peerDependencies": {
    "typescript": "catalog:"
  }
}
