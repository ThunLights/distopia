{
  "name": "distopia-template",
  "private": true,
  "type": "module",
  "exports": {
    "./oxfmt": {
      "import": "./src/oxfmt.ts"
    },
    "./oxlint": {
      "import": "./src/oxlint.ts"
    }
  },
  "scripts": {
    "lint": "oxfmt --check && oxlint",
