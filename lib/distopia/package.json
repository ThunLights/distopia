{
  "name": "distopia",
  "version": "0.0.0",
  "description": "Library for Distopia.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thunlights/distopia.git",
    "directory": "lib/distopia"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "oxfmt --check && oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "distopia-template": "workspace:*",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "tsdown": "0.22.2"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "bun": "catalog:"
  },
  "peerDependencies": {
    "typescript": "catalog:"
  }
}
